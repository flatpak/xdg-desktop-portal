<node name="/" xmlns:doc="http://www.freedesktop.org/dbus/1.0/doc.dtd">
  <!--
      org.freedesktop.handler.portal.Credential:
      @short_description: Credential portal backend interface

      The Credential portal allows sandboxed applications to retrieve
      web credentials.
  -->
  <interface name="org.freedesktop.handler.portal.experimental.Credential">
    <!--
        CreateCredential:
        @parent_window: Identifier for the application window, see :doc:`window-identifiers`
        @app_id: App id of the application
        @app_display_name: Display name of the application.
        @origin: The origin of the request. If specified, must be a valid HTTPS origin; otherwise, the app ID will be used as the origin.
        @top_origin: The top-level origin of the client window. Pass an empty string to denote a same-origin request.
        @request: The credential request parameters.
        @options: Vardict with optional further information, reserved for future use.
        @response: Numeric response. The values allowed match the values allowed for :ref:`org.freedesktop.portal.Request::Response` signal.
        @results: Vardict with the results of the call

        Requests a credential to be created for a particular origin.

        Supported keys in the @request vardict:

        * ``type`` (``s``)
          Type of the created credential.
          Currently, ``publicKey`` is the only supported type.

        * ``@public_key`` (``a{sv}``):
        
           If @type is ``publicKey``, this field contains a dictionary, with a
           single field, ``request_json``, which is a string of JSON that
           corresponds to the WebAuthn ``PublicKeyCredentialCreationOptions`` type.
    -->
    <method name="CreateCredential">
      <arg type="s" name="parent_window" direction="in"/>
      <arg type="s" name="app_id" direction="in"/>
      <arg type="s" name="app_display_name" direction="in"/>
      <arg type="s" name="origin" direction="in"/>
      <arg type="s" name="top_origin" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In6" value="QVariantMap"/>
      <arg type="a{sv}" name="request" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In7" value="QVariantMap"/>
      <arg type="a{sv}" name="options" direction="in"/>
      <arg type="u" name="response" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out1" value="QVariantMap"/>
      <arg type="a{sv}" name="results" direction="out"/>
    </method>

    <!--
        GetCredential:
        @parent_window: Identifier for the application window, see :doc:`window-identifiers`
        @app_id: App id of the application
        @app_display_name: Display name of the application.
        @origin: The origin of the request. If specified, must be a valid HTTPS origin; otherwise, the app ID will be used as the origin.
        @top_origin: The top-level origin of the client window. Pass an empty string to denote a same-origin request.
        @request: The credential request parameters.
        @options: Vardict with optional further information, reserved for future use.
        @response: Numeric response. The values allowed match the values allowed for :ref:`org.freedesktop.portal.Request::Response` signal.
        @results: Vardict with the results of the call

        Supported keys in the @request vardict:

        * ``@public_key`` (``a{sv}``):
        
           A dictionary, with a single field, ``request_json``, which is a
           string of JSON that corresponds to the WebAuthn
           ``PublicKeyCredentialRequestOptions`` type.

        Requests a credential for a particular origin.
    -->
    <method name="GetCredential">
      <arg type="s" name="parent_window" direction="in"/>
      <arg type="s" name="app_id" direction="in"/>
      <arg type="s" name="app_display_name" direction="in"/>
      <arg type="s" name="origin" direction="in"/>
      <arg type="s" name="top_origin" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In6" value="QVariantMap"/>
      <arg type="a{sv}" name="request" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In7" value="QVariantMap"/>
      <arg type="a{sv}" name="options" direction="in"/>
      <arg type="u" name="response" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out1" value="QVariantMap"/>
      <arg type="a{sv}" name="results" direction="out"/>
    </method>

    <property name="version" type="u" access="read"/>
  </interface>
</node>
