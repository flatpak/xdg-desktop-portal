<node name="/" xmlns:doc="http://www.freedesktop.org/dbus/1.0/doc.dtd">
  <!--
      org.freedesktop.impl.portal.experimental.Credential:
      @short_description: Credential portal backend interface

      The Credential portal allows sandboxed applications to retrieve a
      application-scoped web credentials.

      This documentation describes a pre-release version of this
      interface.
  -->
  <interface name="org.freedesktop.impl.portal.experimental.Credential">

    <!--
        Initialize:
        @parent_window: Identifier for the application window, see :doc:`window-identifiers`.
        @origin: The origin of the request.
        @type: Type of the credential to create.  Currently, ``publicKey`` is the only supported type.
        @request_id: ID of the request. An object must be exported here.
        @devices: Initial list of credential sources. Map from source ID to transport. Valid transports are ``BLE``, ``HybridLinked``, ``HybridQr``, ``Internal``, ``Nfc``, ``Usb``. Sources be added or removed during the ceremony.
        @app_id: App id of the application.
        @app_display_name: Display name of the application.
        @app_pid: PID of the application.
        @app_path: Path to the executable of the application.
        @options: Vardict with optional further information.
        @handle: Object path for the `org.freedesktop.portal.experimental.Credential.Ceremony` object representing this call.

        Initializes a credential ceremony with user context and an initial list
        of credential sources. After calling this method, an application should
        subscribe to the ``UserInteracted`` signal on the
        ``org.freedesktop.impl.portal.experimental.Credential.Ceremony``
        exported at the returned @handle, and then call ``Start()`` on that same
        interface to display the credentials.

        TODO: This is a different pattern that does not include a race between
        the frontend and backend, but maybe we shouldn't do something different here?

        Supported keys in the @options vardict include:

        * ``top_origin`` (``s``)
           
          Top-level origin of the request if different from the origin.

        * ``rp_id`` (``s``)
          
          WebAuthn relying party ID. Required if @type is `PublicKeyCreate` or `PublicKeyGet`.
    -->
    <method name="Initialize">
      <arg name="parent_window" type="s" direction="in"/>
      <arg name="origin" type="s" direction="in"/>
      <arg name="type" type="u" direction="in"/>
      <arg name="request_id" type="u" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In4" value="QList&lt;QVariantMap&gt;"/>
      <arg name="devices" type="a(ss)" direction="in"/>
      <arg name="app_id" type="s" direction="in"/>
      <arg name="app_display_name" type="s" direction="in"/>
      <arg name="app_pid" type="u" direction="in"/>
      <arg name="app_path" type="s" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In9" value="QVariantMap"/>
      <arg name="options" type="(ss)" direction="in"/>
      <arg name="handle" type="o" direction="out"/>
    </method>
    <property name="version" type="u" access="read"/>
  </interface>
  <interface name="org.freedesktop.impl.portal.experimental.Credential.Ceremony">
    <!--
     Start:

     Start the credential ceremony with an initial set of available credential sources.

     The frontend should call this method after subscribing to the ``UserInteracted`` signal.
     -->
    <method name="Start">
    </method>
    
    <!--
      NotifyStateChanged:
      @event: The tag-value object representing the updated background information.

      Updates the credential ceremony with background information.

      The frontend will call this method whenever anything on the system
      changes, like new credential sources are discovered, or input is required
      to interact with an authenticator. The backend should present appropriate
      UI to continue to guide the user through the ceremony.

      TODO: Should we just use (ya{sv}) to be more flexible with adding additional properties to each event?

      State objects are tag-value objects (type ``(yv)``). If the event has an
      associated value, the specific type is documented below.

      * ``CEREMONY_COMPLETED = 0x01``
        
        Ceremony completed successfully, and the dialog can be closed.

      * ``NEEDS_PIN = 0x10 (i)``

        @attempts_left (``i``): The number of PIN attempts remaining before the device is locked out and must be reset/wiped. -1 means the number of attempts left is unknown.

        The device needs PIN user verification: prompt the user to enter the
        PIN. The backend must emit the colleged value as an ``EnterClientPin`` event in
        the ``UserInteracted`` signal.

        The backend should consider rate-limiting requests, or requiring the
        user to power-cycle (e.g., unplug and plug back in) the device to
        prevent the device from being locked out due to user error or abuse.

        The backend should warn the user that the credentials may be permanently
        lost if they continue to enter incorrect PINs.

      * ``NEEDS_USER_VERIFICATION = 0x11``

        @attempts_left (``i``): The number of user verification attempts remaining before the built-in user verification methods are disabled until the next successful PIN verification. -1 means the number of attempts left is unknown.

        // TODO: Should we send user-verification modality along with this so
        // the backend UI can show that? Realistically, there's only
        // fingerprint devices on the market.

        The device needs on-device user verification (likely biometrics, or
        can be on-device PIN entry). Prompt the user to interact with the
        device.

        The backend should display the number of built-in user verification
        attempts remaining before falling back to client PIN verification.

      * ``NEEDS_PRESENCE = 0x12``

        Device requires user interaction (e.g. pressing a button), prompt user
        to do so. The device may require additional user verification, but that
        might not be known until after the user taps the device.

      * ``SELECTING_CREDENTIAL = 0x13 (aa{sv})``

        @credentials: A list of metadata for credentials that are able to fulfill the request.

        The device is ready to release credentials, but multiple credentials
        match the request. The backend must prompt the user to select one of the
        credentials.

        Each credential in @credentials contains the following fields:

        * ``id``: An opaque value to send back to the authenticator. It is NOT the WebAuthn ``credentialId``.
        * ``name``: The account name for the credential.
        * ``display_name``: The human-readable username for the credential.

      * ``HYBRID_IDLE = 0x20``

        Hybrid discovery is inactive.

      * ``HYBRID_STARTED = 0x21 (s)``
        
        @qr_data: A string of data that should be displayed as a QR code to the user to invoke the hybrid flow on their peer device.

        Hybrid discovery is activated and is awaiting an invocation on the peer device.

      * ``HYBRID_CONNECTING = 0x22``
        
        The other device has been detected, and a connection is being
        established. The backend should communicate a pending status and prompt
        the user to keep the devices close.

      * ``HYBRID_CONNECTED = 0x23``

        A connection has been established, waiting for user to release
        credential on their device. The backend should prompt the user to follow
        the instructions on the peer device.

      * ``NFC_IDLE = 0x30``

        NFC device discovery is inactive.

      * ``NFC_WAITING = 0x31``

        NFC device discovery is active.

      * ``NFC_CONNECTED = 0x32``
        
        An NFC device has been detected. The backend should prompt the user to
        keep the peer device on the NFC reader so that the ceremony can
        complete.

      * ``USB_IDLE = 0x41``

        USB device discovery is inactive.

      * ``USB_WAITING = 0x42``

        USB device discovery is active.

      * ``USB_SELECTING_DEVICE = 0x43``

        Multiple USB authenticators have been detected and are blinking. The backend
        should prompt the user to interact with one (e.g. press the button) to select it.

      * ``USB_CONNECTED = 0x44``

        USB device connected, prompt user to interact with the device (e.g.
        press the button).
        
        The device may require additional user verification to complete the
        ceremony, but that might not be known until after the user taps the
        device.

      * ``ERROR_AUTHENTICATOR = 0x80000001``

        An unknown authenticator error occurred.

      * ``ERROR_NO_CREDENTIALS = 0x80000002``
        
        The authenticator reported that it has no matching credentials stored.

      * ``ERROR_PIN_ATTEMPTS_EXHAUSTED = 0x80000003``
        
        Too many PIN attempts have been entered, and the authenticator is
        permanently locked out and must be reset.

      * ``ERROR_INTERNAL = 0x80000004``

        An internal portal error occurred.

      * ``ERROR_TIMED_OUT = 0x80000005``

        The credential request has timed out.

      * ``ERROR_CANCELLED = 0x80000006`` 
        
        The user cancelled the request.
    -->
    <method name="NotifyStateChanged">
      <arg name="event" type="(yv)" direction="in"/>
    </method>

    <!--
      Cancel:

      Cancels the credential ceremony.
    -->
    <method name="Cancel">
    </method>
    
    <!--
      UserInteracted:
      @event: A tag and value for a UI event.

      Submits user interaction events to the frontend in response to ceremony
      requirements.

      * ``StartHybridDiscovery = 0x01``

        Request the platform to start hybrid discovery.

      * ``StartUsbDiscovery = 0x02``

        Request the platform to begin discovering USB devices.

      * ``StartNfcDiscovery = 0x03``

        Request the platform to begin discovering NFC devices.

      * ``EnterClientPin = 0x04 (s)``
        
        @client_pin: The PIN entered by the user.

        Send the client PIN to the authenticator for user verification.

        TODO: This is highly sensitive and should not be sent in the clear. We
        should implement some sort of trusted way to send this (Unix datagram socket, or
        encrypting)

      * ``SelectCredential = 0x05 (s)``
        
        @id: The opaque ID representing the selected credential metadata.

        After receiving a ``SelectingCredential`` event on the
        ``NotifyStatusChanged`` method, the user selects a credential from the
        list of credential metadata. The backend must send the ``id`` of that
        metadata to the authenticator to release the credential.

        Note that ``id`` is NOT the WebAuthn credential ID, it is an opaque
        identifier used just for selecting the credential in this ceremony.

        
      * ``CancelRequest = 0x06``
        
        Cancel the credential request for the user.
    -->
    <signal name="UserInteracted">
      <arg name="event" type="(yv)"/>
    </signal>
  </interface>
</node>
