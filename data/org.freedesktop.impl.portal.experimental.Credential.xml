<node name="/" xmlns:doc="http://www.freedesktop.org/dbus/1.0/doc.dtd">
  <!--
      org.freedesktop.impl.portal.experimental.Credential:
      @short_description: Credential portal backend interface

      The Credential portal allows sandboxed applications to retrieve a
      application-scoped web credentials.

      This documentation describes a pre-release version of this
      interface.
  -->
  <interface name="org.freedesktop.impl.portal.experimental.Credential">

    <!--
        Initialize:
        @parent_window: Identifier for the application window, see :doc:`window-identifiers`.
        @origin: The origin of the request.
        @type: Type of the credential to create.  Currently, ``publicKey`` is the only supported type.
        @request_id: ID of the request. An object must be exported here.
        @devices: Initial list of credential sources. Map from source ID to transport. Valid transports are ``BLE``, ``HybridLinked``, ``HybridQr``, ``Internal``, ``Nfc``, ``Usb``. Sources be added or removed during the ceremony.
        @app_id: App id of the application.
        @app_display_name: Display name of the application.
        @app_pid: PID of the application.
        @app_path: Path to the executable of the application.
        @options: Vardict with optional further information.
        @handle: Object path for the :ref:`org.freedesktop.portal.experimental.Credential.Ceremony` object representing this call.

        Initializes a credential ceremony with user context and an initial list
        of credential sources. After calling this method, an application should
        subscribe to the ``UserInteracted`` signal on the
        ``org.freedesktop.impl.portal.experimental.Credential.Ceremony``
        exported at the returned @handle, and then call ``Start()`` on that same
        interface to display the credentials.

        TODO: This is a different pattern that does not include a race between
        the frontend and backend, but maybe we shouldn't do something different here?

        Supported keys in the @options vardict include:

        * ``top_origin`` (``s``)
           
          Top-level origin of the request if different from the origin.

        * ``rp_id`` (``s``)
          
          WebAuthn relying party ID. Required if @type is `PublicKeyCreate` or `PublicKeyGet`.
    -->
    <method name="Initialize">
      <arg name="parent_window" type="s" direction="in"/>
      <arg name="origin" type="s" direction="in"/>
      <arg name="type" type="u" direction="in"/>
      <arg name="request_id" type="u" direction="in"/>
      <arg name="devices" type="a(ss)" direction="in"/>
      <arg name="app_id" type="s" direction="in"/>
      <arg name="app_display_name" type="s" direction="in"/>
      <arg name="app_pid" type="u" direction="in"/>
      <arg name="app_path" type="s" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In1" value="QVariantMap"/>
      <arg name="options" type="(ss)" direction="in"/>
      <arg name="handle" type="o" direction="out"/>
    </method>
    <property name="version" type="u" access="read"/>
  </interface>
  <interface name="org.freedesktop.impl.portal.experimental.Credential.Ceremony">
    <!--
     Start:

     Start the credential ceremony with an initial set of available credential sources.

     The frontend should call this method after subscribing to the ``UserInteracted`` signal.
     -->
    <method name="Start">
    </method>
    
    <!--
      NotifyStateChanged:

      Updates the credential ceremony with background information.

      The frontend will call this method whenever anything on the system
      changes, like new credential sources are discovered, or input is required
      to interact with an authenticator. The backend should present appropriate
      UI to continue to guide the user through the ceremony.
    -->
    <method name="NotifyStateChanged">
      <arg name="event" type="(yv)" direction="in"/>
    </method>

    <!--
      Cancel:

      Cancels the credential ceremony.
    -->
    <method name="Cancel">
    </method>
    
    <!--
      UserInteracted:
      @event: A tag and value for a UI event.

      Submits user interaction events to the frontend in response to ceremony
      requirements.
    -->
    <signal name="UserInteracted">
      <arg name="event" type="(yv)"/>
    </signal>
  </interface>
</node>
