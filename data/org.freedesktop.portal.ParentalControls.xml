<node name="/" xmlns:doc="http://www.freedesktop.org/dbus/1.0/doc.dtd">
  <!--
      org.freedesktop.portal.ParentalControls:
      @short_description: Portal for parental control related user information

      This interface lets applications query parental control related
      age information about the user.

      This documentation describes version 1 of this interface.
  -->
  <interface name="org.freedesktop.portal.ParentalControls">
    <property name="version" type="u" access="read"/>

    <!--
        GetParentalControls:
        @window: Identifier for the window
        @gates: The brackets to query
        @options: Vardict with optional further information
        @handle: Object path for the :ref:`org.freedesktop.portal.Request` object representing this call

        Gets parental control related age information about the current user.

        Each gate represents an bracket to query between.

        For example querying [12,16,18] for a user who is 17 years old
        may return a reply of low=16, high=18

        For the same brackets a 9 year old may return a reply value of
        low=-1 high=12.

        Callers should not query more information than necessary.

        Supported keys in the @options vardict include:

        * ``handle_token`` (``s``)

          A string that will be used as the last element of the @handle. Must be a valid
          object path element. See the :ref:`org.freedesktop.portal.Request` documentation for
          more information about the @handle.

        The following results get returned via the :ref:`org.freedesktop.portal.Request::Response` signal:

        * ``low`` (``i``) and ``high`` (``i``)

          The lower and upper bound of the user's age range relative to the
          provided gates. Each will be either ``-1`` or a gate value
          ``low`` is the lowest gate the user meets or
          exceeds, and ``high`` is the highest gate the user is below.
    -->
    <method name="QueryAgeBracket">
      <arg type="s" name="window" direction="in"/>
      <arg type="au" name="gates" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In3" value="QVariantMap"/>
      <arg type="a{sv}" name="options" direction="in"/>
      <arg type="o" name="handle" direction="out"/>
    </method>
  </interface>
  
</node>
