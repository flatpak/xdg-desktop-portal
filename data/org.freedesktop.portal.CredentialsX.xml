<node name="/" xmlns:doc="http://www.freedesktop.org/dbus/1.0/doc.dtd">
  <!--
      org.freedesktop.portal.CredentialsX:
      @short_description: Credentials portal

      The credentials portal allows applications to request web
      credentials. The user will be prompted to select a credential,
      which the application can use to authenticate.

      Currently the only supported credential type is WebAuthn
      credentials.

      Credentials are created by CreateCredential() and retrieved
      by GetCredential().

      The D-Bus interface for the credentials portal is available
      under the bus name org.freedesktop.portal.Desktop and the
      object path /org/freedesktop/portal/desktop.

      This documentation describes a pre-release version of this
      interface.
  -->
  <interface name="org.freedesktop.portal.CredentialsX">

    <!--
        CreateCredential:
        @parent_window: Identifier for the application window, see :doc:`window-identifiers`
        @origin: The origin of the request. If specified, must be a valid HTTPS origin; otherwise, the app ID will be used as the origin.
        @top_origin: The top-level origin of the client window. Pass an empty string to denote a same-origin request.
        @request: The credential request context and parameters.
        @options: Vardict with optional further information

        Requests a new credential to be stored.

        Supported keys in the @options vardict include:

        * ``handle_token`` (``s``)

          A string that will be used as the last element of the @handle. Must be a valid
          object path element. See the :ref:`org.freedesktop.portal.Request` documentation for
          more information about the @handle.

        The following results get returned via the :ref:`org.freedesktop.portal.Request::Response` signal:

        * ``type`` (``s``)
          Type of the created credential.
          Currently, ``publicKey`` is the only supported type.

        * ``registration_response_json`` (``s``)
          If ``type`` is ``publicKey``, a
          string of JSON that corresonds to the WebAuthn
          ``PublicKeyCredential`` type with the ``response`` field set as
          an ``AuthenticatorAttestationResponse``.
    -->
    <method name="CreateCredential">
      <arg name="parent_window" type="s" direction="in"/>
      <arg name="origin" type="s" direction="in"/>
      <arg name="top_origin" type="s" direction="in"/>
      <!--
        CreateCredentialRequest:
        @type: the type of credential to create. One of
        ["publicKey"].
        @public_key: if @type is "publicKey", this field contains
        a dictionary, with a single field, `request_json`, which
        is a string of JSON that corresponds to the WebAuthn
        PublicKeyCredentialCreationOptions type.
      -->
      <annotation name="org.qtproject.QtDBus.QtTypeName.In3" value="QVariantMap"/>
      <arg name="request" type="a{sv}" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In4" value="QVariantMap"/>
      <arg name="options" type="a{sv}" direction="in"/>
      <arg type="o" name="handle" direction="out"/>
    </method>
    <!--
        GetCredential:
        @parent_window: Identifier for the application window, see :doc:`window-identifiers`
        @origin: The origin of the request. If specified, must be a valid HTTPS origin; otherwise, the app ID will be used as the origin.
        @top_origin: The top-level origin of the client window. Pass an empty string to denote a same-origin request.
        @request: The credential request context and parameters.
        @options: Vardict with optional further information.

        Returns a credential.

        Supported keys in the @request vardict include:

        * ``public_key`` (``a{sv}``)

          A dictionary that contains a field `request_json`, which
          is a string of JSON that corresponds to the WebAuthn
          PublicKeyCredentialRequestOptions type.

        Supported keys in the @options vardict include:

        * ``handle_token`` (``s``)

          A string that will be used as the last element of the @handle. Must be a valid
          object path element. See the :ref:`org.freedesktop.portal.Request` documentation for
          more information about the @handle.

        The following results get returned via the :ref:`org.freedesktop.portal.Request::Response` signal:

        * ``type`` (``s``)
          Type of the returned credential.
          Currently, ``publicKey`` is the only supported type.

        * ``authentication_response_json`` (``s``)
          If ``type`` is ``publicKey``, a
          string of JSON that corresonds to the WebAuthn
          ``PublicKeyCredential`` type with the ``response`` field set as
          an ``AuthenticatorAssertionResponse``.
    -->
    <method name="GetCredential">
      <arg name="parent_window" type="s" direction="in"/>
      <arg name="origin" type="s" direction="in"/>
      <arg name="top_origin" type="s" direction="in"/>
      <!--
        GetCredentialRequest:
        @origin: the web origin at which the request is made.
        @is_same_origin: Whether the top-level origin of the client
        is the same as the origin for which the request is made.
        @type: the type of credential to create. One of
        ["publicKey"].
        @public_key: if @type is "publicKey", this field contains
        the a dictionary, with a single field, `request_json`, which
        is a string of JSON that corresponds to the WebAuthn
        PublicKeyCredentialRequestOptions type.
      -->
      <annotation name="org.qtproject.QtDBus.QtTypeName.In3" value="QVariantMap"/>
      <arg name="request" type="a{sv}" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In4" value="QVariantMap"/>
      <arg name="options" type="a{sv}" direction="in"/>
      <arg type="o" name="handle" direction="out"/>
    </method>

    <!--
      Whether conditional mediation is supported for credential registration.

      https://www.w3.org/TR/webauthn-3/#dom-clientcapability-conditionalcreate
    -->
    <property name="ConditionalCreate" type="b" access="read" />

    <!--
      Whether conditional mediation is supported for authentication.

      https://www.w3.org/TR/webauthn-3/#dom-clientcapability-conditionalget
    -->
    <property name="ConditionalGet" type="b" access="read" /> 

    <!--
      Whether hybrid authenticators are supported.

      https://www.w3.org/TR/webauthn-3/#dom-clientcapability-hybridtransport
    -->
    <property name="HybridTransport" type="b" access="read" /> 

    <!--
      Whether a passkey platform authenticator (local or via hybrid transport) is accessible via this API.
      https://www.w3.org/TR/webauthn-3/#dom-clientcapability-passkeyplatformauthenticator
    -->
    <property name="PasskeyPlatformAuthenticator" type="b" access="read" /> 

    <!--
      Whether a user-verifying platform authenticator is available via this API.

      https://www.w3.org/TR/webauthn-3/#dom-clientcapability-userverifyingplatformauthenticator
    -->
    <property name="UserVerifyingPlatformAuthenticator" type="b" access="read" />

    <!--
      Whether matching origins using WebAuthn Related Origin Requests is supported.

      https://www.w3.org/TR/webauthn-3/#dom-clientcapability-relatedorigins
    -->
    <property name="RelatedOrigins" type="b" access="read" /> 

    <!--
      Whether WebAuthn signalAllAcceptedCredentials() is supported.

      https://www.w3.org/TR/webauthn-3/#dom-clientcapability-signalallacceptedcredentials
    -->
    <property name="SignalAllAcceptedCredentials" type="b" access="read" /> 

    <!--
      Whether WebAuthn signalCurrentUserDetails() is supported.

      https://www.w3.org/TR/webauthn-3/#dom-clientcapability-signalcurrentuserdetails
    -->
    <property name="SignalCurrentUserDetails" type="b" access="read" /> 

    <!--
      The WebAuthn Client supports signalUnknownCredential().

      https://www.w3.org/TR/webauthn-3/#dom-clientcapability-signalunknowncredential
    -->
    <property name="SignalUnknownCredential" type="b" access="read" /> 

    <property name="version" type="u" access="read"/>
  </interface>
</node>
