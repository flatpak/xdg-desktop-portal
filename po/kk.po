#: src/background.c:941
#, c-format
msgid "Allow %s to Run in the Background?"
msgstr "%s үшін фондық режимде жұмыс істеуіне рұқсат беру керек пе?"

#: src/background.c:945
#, c-format
msgid "%s wants to be started automatically and run in the background"
msgstr "%s автоматты түрде іске қосылып, фондық режимде жұмыс істегісі келеді"

#: src/background.c:947
#, c-format
msgid "%s wants to run in the background"
msgstr "%s фондық режимде жұмыс істегісі келеді"

#: src/background.c:948
msgid ""
"The ‘run in background’ permission can be changed at any time from the app "
"settings"
msgstr ""
"‘фондық режимде жұмыс істеу’ рұқсатын кез келген уақытта қолданба "
"баптауларынан өзгертуге болады"

#: src/background.c:952
msgid "Don't allow"
msgstr "Рұқсат етпеу"

#: src/background.c:953 src/screenshot.c:275 src/wallpaper.c:192
msgid "Allow"
msgstr "Рұқсат ету"

#: src/camera.c:105
#, c-format
msgid "Allow %s to Use the Camera?"
msgstr "%s камераны пайдалануға рұқсат беру керек пе?"

#: src/camera.c:106
#, c-format
msgid "%s wants to access the camera"
msgstr "%s камераға қол жеткізгісі келеді"

#: src/camera.c:110
msgid "Allow Apps to Use the Camera?"
msgstr "Қолданбалардың камераны пайдалануға рұқсат беру керек пе?"

#: src/camera.c:111
msgid "An app wants to access the camera"
msgstr "Қолданба камераға қол жеткізгісі келеді"

#: src/camera.c:114 src/screenshot.c:327 src/wallpaper.c:208
msgid "This permission can be changed at any time from the privacy settings"
msgstr "Бұл рұқсатты кез келген уақытта жекелік баптауларынан өзгертуге болады"

#: src/dynamic-launcher.c:127
#, c-format
msgid "Desktop file id missing .desktop suffix: %s"
msgstr "Жұмыс үстелі файлының идентификаторында .desktop суффиксі жоқ: %s"

#: src/dynamic-launcher.c:138
#, c-format
msgid "Desktop file id is not valid"
msgstr "Жұмыс үстелі файлының идентификаторы жарамсыз"

#: src/dynamic-launcher.c:310
#, c-format
msgid "Desktop entry given to Install() not a valid key file"
msgstr ""
"Install() функциясына берілген жұмыс үстелі элементі жарамды кілт файлы емес"

#: src/dynamic-launcher.c:323
#, c-format
msgid "Desktop entry given to Install() must have exactly one group"
msgstr ""
"Install() функциясына берілген жұмыс үстелі элементінде тек бір топ болуы "
"тиіс"

#: src/dynamic-launcher.c:361
#, c-format
msgid "Token given is invalid: %s"
msgstr "Берілген токен жарамсыз: %s"

#: src/dynamic-launcher.c:404
#, c-format
msgid "Desktop entry given to Install() not valid"
msgstr "Install() функциясына берілген жұмыс үстелі элементі жарамсыз"

#: src/dynamic-launcher.c:413 src/dynamic-launcher.c:873
#: src/dynamic-launcher.c:922
#, c-format
msgid "Desktop file exceeds max size (%d): %s"
msgstr "Жұмыс үстелі файлы максималды өлшемнен (%d) асады: %s"

#: src/dynamic-launcher.c:597
#, fuzzy, c-format
msgid "Given URI is invalid: %s"
msgstr "Берілген URL жарамсыз: %s"

#: src/dynamic-launcher.c:619
#, c-format
msgid "Invalid launcher type: %x"
msgstr "Жөнелткіш түрі жарамсыз: %x"

#: src/dynamic-launcher.c:626
#, c-format
msgid "Unsupported launcher type: %x"
msgstr "Жөнелткіш түріне қолдау көрсетілмейді: %x"

#: src/dynamic-launcher.c:692 src/dynamic-launcher.c:767
msgid "Dynamic launcher icon failed validation"
msgstr "Динамикалық жөнелткіш таңбашасын тексеру сәтсіз аяқталды"

#: src/dynamic-launcher.c:783
#, c-format
msgid "RequestInstallToken() not allowed for app id %s"
msgstr "%s қолданба идентификаторы үшін RequestInstallToken() рұқсат етілмеген"

#: src/dynamic-launcher.c:962
#, c-format
msgid "Desktop file '%s' icon at unrecognized path"
msgstr "'%s' жұмыс үстелі файлының таңбашасы танылмаған жолда орналасқан"

#: src/dynamic-launcher.c:985
#, c-format
msgid "Desktop file '%s' icon failed to serialize"
msgstr "'%s' жұмыс үстелі файлының таңбашасын сериялау сәтсіз аяқталды"

#: src/dynamic-launcher.c:1024
#, c-format
msgid "No dynamic launcher exists with id '%s'"
msgstr "'%s' идентификаторы бар динамикалық жөнелткіш табылмады"

#: src/dynamic-launcher.c:1043
#, c-format
msgid "Failed to create GDesktopAppInfo for launcher with id '%s'"
msgstr ""
"'%s' идентификаторы бар іске қосқыш үшін GDesktopAppInfo жасау сәтсіз "
"аяқталды"

#: src/location.c:555
msgid "Deny Access"
msgstr "Қол жеткізуге рұқсат бермеу"

#: src/location.c:557
msgid "Grant Access"
msgstr "Қол жеткізуге рұқсат беру"

#: src/location.c:563
#, c-format
msgid "Allow %s to Access Your Location?"
msgstr ""
"%s үшін сіздің орналасқан жеріңізге қол жеткізуге рұқсат беру керек пе?"

#: src/location.c:573
#, c-format
msgid "%s wants to use your location"
msgstr "%s сіздің орналасқан жеріңізді пайдаланғысы келеді"

#: src/location.c:579
msgid "Allow Apps to Access Your Location?"
msgstr ""
"Қолданбаларға сіздің орналасқан жеріңізге қол жеткізуге рұқсат беру керек пе?"

#: src/location.c:580
msgid "An app wants to use your location"
msgstr "Қолданба сіздің орналасқан жеріңізді пайдаланғысы келеді"

#: src/location.c:583
msgid "Location access can be changed at any time from the privacy settings"
msgstr ""
"Орналасқан жерге қол жеткізуді кез келген уақытта жекелік баптауларынан "
"өзгертуге болады"

#: src/screenshot.c:273 src/wallpaper.c:190
msgid "Deny"
msgstr "Рұқсат бермеу"

#: src/screenshot.c:299
#, c-format
msgid "Allow %s to Take Screenshots?"
msgstr "%s үшін скриншоттар түсіруге рұқсат беру керек пе?"

#: src/screenshot.c:300
#, c-format
msgid "%s wants to take screenshots at any time"
msgstr "%s кез келген уақытта скриншоттар түсіргісі келеді"

#: src/screenshot.c:304
#, c-format
msgid "Allow %s to Take a Screenshot?"
msgstr "%s скриншот түсіруге рұқсат беру керек пе?"

#: src/screenshot.c:305
#, c-format
msgid "%s wants to take a screenshot"
msgstr "%s скриншот түсіргісі келеді"

#. Note: this will set the screenshot permission for all unsandboxed
#. * apps for which an app ID can't be determined.
#.
#: src/screenshot.c:316
msgid "Allow Apps to Take Screenshots?"
msgstr "Қолданбаларға скриншоттар түсіруге рұқсат беру керек пе?"

#: src/screenshot.c:317
msgid "An app wants to take screenshots at any time"
msgstr "Қолданба кез келген уақытта скриншоттар түсіргісі келеді"

#: src/screenshot.c:321
msgid "Allow to Take a Screenshot?"
msgstr "Скриншот түсіруге рұқсат беру керек пе?"

#: src/screenshot.c:322
msgid "An app wants to take a screenshot"
msgstr "Қолданба скриншот түсіргісі келеді"

#: src/settings.c:196 src/settings.c:235
msgid "Requested setting not found"
msgstr "Сұралған баптау табылмады"

#: src/usb.c:1333
msgid "Device not available"
msgstr "Құрылғы қолжетімді емес"

#: src/usb.c:1347
msgid "Not allowed"
msgstr "Рұқсат етілмеген"

#: src/wallpaper.c:198
#, c-format
msgid "Allow %s to Set Backgrounds?"
msgstr "%s үшін фондарды орнатуға рұқсат беру керек пе?"

#: src/wallpaper.c:199
#, c-format
msgid "%s wants to change the background image"
msgstr "%s фон суретін өзгерткісі келеді"

#: src/wallpaper.c:204
msgid "Allow Apps to Set Backgrounds?"
msgstr "Қолданбалардың фондарды орнатуға рұқсат беру керек пе?"

#: src/wallpaper.c:205
msgid "An app wants to change the background image"
msgstr "Қолданба фон суретін өзгерткісі келеді"
