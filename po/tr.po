#: src/background.c:941
#, c-format
msgid "Allow %s to Run in the Background?"
msgstr "%s, Arka Planda Çalışsın Mı?"

#: src/background.c:945
#, c-format
msgid "%s wants to be started automatically and run in the background"
msgstr "%s kendiliğinden başlatılmayı ve arka planda çalışmayı istiyor"

#: src/background.c:947
#, c-format
msgid "%s wants to run in the background"
msgstr "%s arka planda çalışmak istiyor"

#: src/background.c:948
msgid ""
"The ‘run in background’ permission can be changed at any time from the app "
"settings"
msgstr ""
"‘Arka planda çalış’ izni, uygulama ayarlarından dilediğince değiştirilebilir"

#: src/background.c:952
msgid "Don't allow"
msgstr "İzin Verme"

#: src/background.c:953 src/screenshot.c:275 src/wallpaper.c:192
msgid "Allow"
msgstr "İzin Ver"

#: src/camera.c:105
#, c-format
msgid "Allow %s to Use the Camera?"
msgstr "%s, Kamerayı Kullansın Mı?"

#: src/camera.c:106
#, c-format
msgid "%s wants to access the camera"
msgstr "%s kameraya erişmek istiyor"

#: src/camera.c:110
msgid "Allow Apps to Use the Camera?"
msgstr "Uygulamalar Kamerayı Kullanabilsin Mi?"

#: src/camera.c:111
msgid "An app wants to access the camera"
msgstr "Bir uygulama kameraya erişmek istiyor"

#: src/camera.c:114 src/screenshot.c:327 src/wallpaper.c:208
msgid "This permission can be changed at any time from the privacy settings"
msgstr "Bu izin, gizlilik ayarlarından dilediğince değiştirilebilir"

#: src/dynamic-launcher.c:127
#, c-format
msgid "Desktop file id missing .desktop suffix: %s"
msgstr "Desktop dosya kimliğinin .desktop son eki eksik: %s"

#: src/dynamic-launcher.c:138
#, c-format
msgid "Desktop file id is not valid"
msgstr "Desktop dosya kimliği geçersiz"

#: src/dynamic-launcher.c:310
#, c-format
msgid "Desktop entry given to Install() not a valid key file"
msgstr ""
"Install() işlevine verilen desktop girdisi geçerli anahtar dosyası değil"

#: src/dynamic-launcher.c:323
#, c-format
msgid "Desktop entry given to Install() must have exactly one group"
msgstr ""
"Install() işlevine verilen desktop girdisi yalnızca tek gruplu olmalıdır"

#: src/dynamic-launcher.c:361
#, c-format
msgid "Token given is invalid: %s"
msgstr "Verilen jeton geçersiz: %s"

#: src/dynamic-launcher.c:404
#, c-format
msgid "Desktop entry given to Install() not valid"
msgstr "Install() işlevine verilen desktop girdisi geçersiz"

#: src/dynamic-launcher.c:413 src/dynamic-launcher.c:873
#: src/dynamic-launcher.c:922
#, c-format
msgid "Desktop file exceeds max size (%d): %s"
msgstr "Desktop dosyası en çok boyutu (%d) aşıyor : %s"

#: src/dynamic-launcher.c:597
#, c-format
msgid "Given URI is invalid: %s"
msgstr "Verilen URI geçersiz: %s"

#: src/dynamic-launcher.c:619
#, c-format
msgid "Invalid launcher type: %x"
msgstr "Geçersiz başlatıcı türü: %x"

#: src/dynamic-launcher.c:626
#, c-format
msgid "Unsupported launcher type: %x"
msgstr "Desteklenmeyen başlatıcı türü: %x"

#: src/dynamic-launcher.c:692 src/dynamic-launcher.c:767
msgid "Dynamic launcher icon failed validation"
msgstr "Dinamik başlatıcı simgesi doğrulanamadı"

#: src/dynamic-launcher.c:783
#, c-format
msgid "RequestInstallToken() not allowed for app id %s"
msgstr ""
"RequestInstallToken() işlevine %s uygulama kimliği için izin verilmiyor"

#: src/dynamic-launcher.c:962
#, c-format
msgid "Desktop file '%s' icon at unrecognized path"
msgstr "Tanınmayan yolda desktop dosyası '%s' simgesi"

#: src/dynamic-launcher.c:985
#, c-format
msgid "Desktop file '%s' icon failed to serialize"
msgstr "Desktop dosyası '%s' simgesi serileştirilemedi"

#: src/dynamic-launcher.c:1024
#, c-format
msgid "No dynamic launcher exists with id '%s'"
msgstr "'%s' kimliğine sahip dinamik başlatıcı yok"

#: src/dynamic-launcher.c:1043
#, c-format
msgid "Failed to create GDesktopAppInfo for launcher with id '%s'"
msgstr "'%s' kimliğine sahip başlatıcı için GDesktopAppInfo oluşturulamadı"

#: src/location.c:555
msgid "Deny Access"
msgstr "Erişimi Reddet"

#: src/location.c:557
msgid "Grant Access"
msgstr "Erişim İzni Ver"

#: src/location.c:563
#, c-format
msgid "Allow %s to Access Your Location?"
msgstr "%s, Konumunuza Erişsin Mi?"

#: src/location.c:573
#, c-format
msgid "%s wants to use your location"
msgstr "%s konumunuzu kullanmak istiyor"

#: src/location.c:579
msgid "Allow Apps to Access Your Location?"
msgstr "Uygulamalar Konumunuza Erişsin Mi?"

#: src/location.c:580
msgid "An app wants to use your location"
msgstr "Bir uygulama konumunuzu kullanmak istiyor"

#: src/location.c:583
msgid "Location access can be changed at any time from the privacy settings"
msgstr "Konum erişimi, gizlilik ayarlarından dilediğince değiştirilebilir"

#: src/screenshot.c:273 src/wallpaper.c:190
msgid "Deny"
msgstr "Reddet"

#: src/screenshot.c:299
#, c-format
msgid "Allow %s to Take Screenshots?"
msgstr "%s, Ekran Görüntüleri Alsın Mı?"

#: src/screenshot.c:300
#, c-format
msgid "%s wants to take screenshots at any time"
msgstr "%s dilediğince ekran görüntüsü almak istiyor"

#: src/screenshot.c:304
#, c-format
msgid "Allow %s to Take a Screenshot?"
msgstr "%s, Ekran Görüntüsü Alsın Mı?"

#: src/screenshot.c:305
#, c-format
msgid "%s wants to take a screenshot"
msgstr "%s ekran görüntüsü almak istiyor."

#. Note: this will set the screenshot permission for all unsandboxed
#. * apps for which an app ID can't be determined.
#.
#: src/screenshot.c:316
msgid "Allow Apps to Take Screenshots?"
msgstr "Uygulamalar Ekran Görüntüleri Alabilsin Mi?"

#: src/screenshot.c:317
msgid "An app wants to take screenshots at any time"
msgstr "Bir uygulama dilediğince ekran görüntüsü almak istiyor"

#: src/screenshot.c:321
msgid "Allow to Take a Screenshot?"
msgstr "Ekran Görüntüsü Alabilsin Mi?"

#: src/screenshot.c:322
msgid "An app wants to take a screenshot"
msgstr "Bir uygulama ekran görüntüsü almak istiyor"

#: src/settings.c:196 src/settings.c:235
msgid "Requested setting not found"
msgstr "İstenen ayar bulunamadı"

#: src/usb.c:1333
msgid "Device not available"
msgstr "Aygıt kullanılır değil"

#: src/usb.c:1347
msgid "Not allowed"
msgstr "İzin verilmedi"

#: src/wallpaper.c:198
#, c-format
msgid "Allow %s to Set Backgrounds?"
msgstr "%s, Arka Planı Değiştirebilsin Mi?"

#: src/wallpaper.c:199
#, c-format
msgid "%s wants to change the background image"
msgstr "%s arka plan görüntüsünü değiştirmek istiyor"

#: src/wallpaper.c:204
msgid "Allow Apps to Set Backgrounds?"
msgstr "Uygulamalar Arka Planı Değiştirebilsin Mi?"

#: src/wallpaper.c:205
msgid "An app wants to change the background image"
msgstr "Bir uygulama arka plan görüntüsünü değiştirmek istiyor"
