#: src/background.c:941
#, c-format
msgid "Allow %s to Run in the Background?"
msgstr "Engedélyezi a(z) %s számára, hogy a háttérben fusson?"

#: src/background.c:945
#, c-format
msgid "%s wants to be started automatically and run in the background"
msgstr "A(z) %s azt kéri, hogy automatikusan elinduljon és a háttérben fusson."

#: src/background.c:947
#, c-format
msgid "%s wants to run in the background"
msgstr "A(z) %s azt kéri, hogy a háttérben fusson."

#: src/background.c:948
msgid ""
"The ‘run in background’ permission can be changed at any time from the app "
"settings"
msgstr ""
"A „háttérben való futás” engedély bármikor megváltoztatható az alkalmazás "
"beállításaiban."

#: src/background.c:952
msgid "Don't allow"
msgstr "Ne engedélyezze"

#: src/background.c:953 src/screenshot.c:275 src/wallpaper.c:192
msgid "Allow"
msgstr "Engedélyezés"

#: src/camera.c:105
#, c-format
msgid "Allow %s to Use the Camera?"
msgstr "Engedélyezi a(z) %s számára, hogy használja a kamerát?"

#: src/camera.c:106
#, c-format
msgid "%s wants to access the camera"
msgstr "A(z) %s használni szeretné a kameráját."

#: src/camera.c:110
msgid "Allow Apps to Use the Camera?"
msgstr "Engedélyezi az alkalmazások számára, hogy használják a kamerát?"

#: src/camera.c:111
msgid "An app wants to access the camera"
msgstr "Egy alkalmazás használni szeretné a kameráját."

#: src/camera.c:114 src/screenshot.c:327 src/wallpaper.c:208
msgid "This permission can be changed at any time from the privacy settings"
msgstr ""
"Ez az engedély bármikor megváltoztatható az adatvédelmi beállításokban."

#: src/dynamic-launcher.c:127
#, c-format
msgid "Desktop file id missing .desktop suffix: %s"
msgstr "A desktop fájl azonosítójából hiányzik a .desktop utótag: %s"

#: src/dynamic-launcher.c:138
#, c-format
msgid "Desktop file id is not valid"
msgstr "A desktop fájl azonosítója érvénytelen"

#: src/dynamic-launcher.c:316
#, c-format
msgid "Desktop entry given to Install() not a valid key file"
msgstr ""
"Az Install() számára megadott desktop bejegyzés nem egy érvényes kulcsfájl"

#: src/dynamic-launcher.c:329
#, c-format
msgid "Desktop entry given to Install() must have exactly one group"
msgstr ""
"Az Install() számára megadott desktop bejegyzésnek pontosan egy csoportot "
"kell tartalmaznia"

#: src/dynamic-launcher.c:367
#, c-format
msgid "Token given is invalid: %s"
msgstr "A megadott token érvénytelen: %s"

#: src/dynamic-launcher.c:410
#, c-format
msgid "Desktop entry given to Install() not valid"
msgstr "Az Install() számára megadott desktop bejegyzés érvénytelen"

#: src/dynamic-launcher.c:419 src/dynamic-launcher.c:879
#: src/dynamic-launcher.c:928
#, c-format
msgid "Desktop file exceeds max size (%d): %s"
msgstr "A desktop fájl túllépi a maximális méretet (%d): %s"

#: src/dynamic-launcher.c:603
#, fuzzy, c-format
msgid "Given URI is invalid: %s"
msgstr "A megadott URL érvénytelen: %s"

#: src/dynamic-launcher.c:625
#, c-format
msgid "Invalid launcher type: %x"
msgstr "Az indító típusa érvénytelen: %x"

#: src/dynamic-launcher.c:632
#, c-format
msgid "Unsupported launcher type: %x"
msgstr "Az indító típusa nem támogatott: %x"

#: src/dynamic-launcher.c:698 src/dynamic-launcher.c:773
msgid "Dynamic launcher icon failed validation"
msgstr "A dinamikus indító ikont nem sikerült érvényesíteni"

#: src/dynamic-launcher.c:789
#, c-format
msgid "RequestInstallToken() not allowed for app id %s"
msgstr ""
"A RequestInstallToken() nem engedélyezett ennek az alkalmazás azonosítónak: "
"%s"

#: src/dynamic-launcher.c:968
#, c-format
msgid "Desktop file '%s' icon at unrecognized path"
msgstr "A(z) „%s” desktop fájl ikonjának nem ismerhető fel az elérési útja"

#: src/dynamic-launcher.c:991
#, c-format
msgid "Desktop file '%s' icon failed to serialize"
msgstr "A(z) „%s” desktop fájl ikonját nem sikerült feldolgozni."

#: src/dynamic-launcher.c:1030
#, c-format
msgid "No dynamic launcher exists with id '%s'"
msgstr "Nem létezik dinamikus indító a(z) „%s” azonosítóval"

#: src/dynamic-launcher.c:1049
#, c-format
msgid "Failed to create GDesktopAppInfo for launcher with id '%s'"
msgstr ""
"Nem sikerült létrehozni a GDesktopAppInfo-t a(z) „%s” azonosítójú indítónak"

#: src/location.c:555
msgid "Deny Access"
msgstr "Hozzáférés megtagadása"

#: src/location.c:557
msgid "Grant Access"
msgstr "Hozzáférés megadása"

#: src/location.c:563
#, c-format
msgid "Allow %s to Access Your Location?"
msgstr "Hozzáférést ad a(z) %s számára a tartózkodási helyéhez?"

#: src/location.c:573
#, c-format
msgid "%s wants to use your location"
msgstr "A(z) %s használni szeretné a tartózkodási helyét."

#: src/location.c:579
msgid "Allow Apps to Access Your Location?"
msgstr "Hozzáférést ad az alkalmazásoknak a tartózkodási helyéhez?"

#: src/location.c:580
msgid "An app wants to use your location"
msgstr "Egy alkalmazás használni szeretné a tartózkodási helyét."

#: src/location.c:583
msgid "Location access can be changed at any time from the privacy settings"
msgstr ""
"A tartózkodási helyhez való hozzáférés bármikor megváltoztatható az "
"adatvédelmi beállításokban."

#: src/screenshot.c:273 src/wallpaper.c:190
msgid "Deny"
msgstr "Elutasítás"

#: src/screenshot.c:299
#, c-format
msgid "Allow %s to Take Screenshots?"
msgstr "Engedélyezi a(z) %s számára, hogy képernyőképeket készítsen?"

#: src/screenshot.c:300
#, c-format
msgid "%s wants to take screenshots at any time"
msgstr "A(z) %s azt szeretné, hogy bármikor készíthessen képernyőképeket."

#: src/screenshot.c:304
#, c-format
msgid "Allow %s to Take a Screenshot?"
msgstr "Engedélyezi a(z) %s számára, hogy egy képernyőképet készítsen?"

#: src/screenshot.c:305
#, c-format
msgid "%s wants to take a screenshot"
msgstr "A(z) %s egy képernyőképet szeretne csinálni"

#. Note: this will set the screenshot permission for all unsandboxed
#. * apps for which an app ID can't be determined.
#.
#: src/screenshot.c:316
msgid "Allow Apps to Take Screenshots?"
msgstr "Engedélyezi az alkalmazásoknak, hogy képernyőképeket készítsenek?"

#: src/screenshot.c:317
msgid "An app wants to take screenshots at any time"
msgstr ""
"Egy alkalmazás azt szeretné, hogy bármikor készíthessen képernyőképeket."

#: src/screenshot.c:321
msgid "Allow to Take a Screenshot?"
msgstr "Engedélyezi a képernyőkép készítést?"

#: src/screenshot.c:322
msgid "An app wants to take a screenshot"
msgstr "Egy alkalmazás egy képernyőképet szeretne csinálni"

#: src/settings.c:196 src/settings.c:235
msgid "Requested setting not found"
msgstr "A kért beállítás nem található"

#: src/usb.c:1333
msgid "Device not available"
msgstr "Az eszköz nem elérhető"

#: src/usb.c:1347
msgid "Not allowed"
msgstr "Nem engedélyezett"

#: src/wallpaper.c:198
#, c-format
msgid "Allow %s to Set Backgrounds?"
msgstr "Engedélyezi a(z) %s számára, hogy háttereket állítson be?"

#: src/wallpaper.c:199
#, c-format
msgid "%s wants to change the background image"
msgstr "A(z) %s azt kéri, hogy megváltoztathassa a háttérképet."

#: src/wallpaper.c:204
msgid "Allow Apps to Set Backgrounds?"
msgstr "Engedélyezi az alkalmazások számára, hogy háttereket állítsanak be?"

#: src/wallpaper.c:205
msgid "An app wants to change the background image"
msgstr "Egy alkalmazás azt kéri, hogy megváltoztathassa a háttérképet."

