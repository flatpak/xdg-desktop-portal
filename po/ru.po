#: src/background.c:941
#, c-format
msgid "Allow %s to Run in the Background?"
msgstr "Разрешить приложению \"%s\" работать в фоне?"

#: src/background.c:945
#, c-format
msgid "%s wants to be started automatically and run in the background"
msgstr "Приложение \"%s\" хочет запускаться автоматически и работать в фоне"

#: src/background.c:947
#, c-format
msgid "%s wants to run in the background"
msgstr "Приложение \"%s\" хочет работать в фоне"

#: src/background.c:948
msgid ""
"The ‘run in background’ permission can be changed at any time from the app "
"settings"
msgstr ""
"Разрешение на ‘работу в фоне’ можно изменить в любой момент в настройках "
"приложения"

#: src/background.c:952
msgid "Don't allow"
msgstr "Запретить"

#: src/background.c:953 src/screenshot.c:275 src/wallpaper.c:192
msgid "Allow"
msgstr "Разрешить"

#: src/camera.c:105
#, c-format
msgid "Allow %s to Use the Camera?"
msgstr "Разрешить приложению \"%s\" использовать камеру?"

#: src/camera.c:106
#, c-format
msgid "%s wants to access the camera"
msgstr "Приложение \"%s\" хочет получить доступ к камере"

#: src/camera.c:110
msgid "Allow Apps to Use the Camera?"
msgstr "Разрешить приложениям использовать камеру?"

#: src/camera.c:111
msgid "An app wants to access the camera"
msgstr "Приложение хочет получить доступ к камере"

#: src/camera.c:114 src/screenshot.c:327 src/wallpaper.c:208
msgid "This permission can be changed at any time from the privacy settings"
msgstr ""
"Это разрешение можно изменить в любой момент в настройках конфиденциальности"

#: src/dynamic-launcher.c:127
#, c-format
msgid "Desktop file id missing .desktop suffix: %s"
msgstr "В идентификаторе desktop-файла отсутствует суффикс .desktop: %s"

#: src/dynamic-launcher.c:138
#, c-format
msgid "Desktop file id is not valid"
msgstr "Идентификатор desktop-файла недействителен"

#: src/dynamic-launcher.c:316
#, c-format
msgid "Desktop entry given to Install() not a valid key file"
msgstr ""
"Desktop-запись, переданная в Install(), не содержит действительного файла "
"ключа"

#: src/dynamic-launcher.c:329
#, c-format
msgid "Desktop entry given to Install() must have exactly one group"
msgstr "Desktop-запись, переданная в Install(), должна иметь ровно одну группу"

#: src/dynamic-launcher.c:368
#, c-format
msgid "Token given is invalid: %s"
msgstr "Указанный токен недействителен: %s"

#: src/dynamic-launcher.c:411
#, c-format
msgid "Desktop entry given to Install() not valid"
msgstr "Desktop-запись, переданная в Install(), недействительна"

#: src/dynamic-launcher.c:420 src/dynamic-launcher.c:896
#: src/dynamic-launcher.c:945
#, c-format
msgid "Desktop file exceeds max size (%d): %s"
msgstr "Desktop-файл превышает максимальный размер (%d): %s"

#: src/dynamic-launcher.c:618
#, fuzzy, c-format
msgid "Given URI is invalid: %s"
msgstr "Указанный URL недействителен: %s"

#: src/dynamic-launcher.c:640
#, c-format
msgid "Invalid launcher type: %x"
msgstr "Недействительный тип программы запуска: %x"

#: src/dynamic-launcher.c:647
#, c-format
msgid "Unsupported launcher type: %x"
msgstr "Неподдерживаемый тип программы запуска: %x"

#: src/dynamic-launcher.c:713 src/dynamic-launcher.c:788
msgid "Dynamic launcher icon failed validation"
msgstr "Значок динамической программы запуска не прошел проверку"

#: src/dynamic-launcher.c:806
#, c-format
msgid "RequestInstallToken() not allowed for app id %s"
msgstr "RequestInstallToken() не разрешен для идентификатора приложения %s"

#: src/dynamic-launcher.c:985
#, c-format
msgid "Desktop file '%s' icon at unrecognized path"
msgstr "Значок desktop-файла '%s' находится по нераспознанному пути"

#: src/dynamic-launcher.c:1008
#, c-format
msgid "Desktop file '%s' icon failed to serialize"
msgstr "Не удалось сериализовать значок desktop-файла '%s'"

#: src/dynamic-launcher.c:1047
#, c-format
msgid "No dynamic launcher exists with id '%s'"
msgstr "Не существует динамической программы запуска с идентификатором '%s'"

#: src/dynamic-launcher.c:1066
#, c-format
msgid "Failed to create GDesktopAppInfo for launcher with id '%s'"
msgstr ""
"Не удалось создать GDesktopAppInfo для программы запуска с идентификатором "
"'%s'"

#: src/location.c:555
msgid "Deny Access"
msgstr "Отказать в доступе"

#: src/location.c:557
msgid "Grant Access"
msgstr "Предоставить доступ"

#: src/location.c:563
#, c-format
msgid "Allow %s to Access Your Location?"
msgstr "Разрешить приложению \"%s\" доступ к вашему местоположению?"

#: src/location.c:573
#, c-format
msgid "%s wants to use your location"
msgstr "Приложение \"%s\" хочет использовать ваше местоположение"

#: src/location.c:579
msgid "Allow Apps to Access Your Location?"
msgstr "Разрешить приложениям доступ к вашему местоположению?"

#: src/location.c:580
msgid "An app wants to use your location"
msgstr "Приложение хочет использовать ваше местоположение"

#: src/location.c:583
msgid "Location access can be changed at any time from the privacy settings"
msgstr ""
"Доступ к местоположению можно изменить в любой момент в настройках "
"конфиденциальности"

#: src/screenshot.c:273 src/wallpaper.c:190
msgid "Deny"
msgstr "Отказать"

#: src/screenshot.c:299
#, c-format
msgid "Allow %s to Take Screenshots?"
msgstr "Разрешить приложению \"%s\" делать снимки экрана?"

#: src/screenshot.c:300
#, c-format
msgid "%s wants to take screenshots at any time"
msgstr "Приложение \"%s\" хочет делать снимки экрана в любое время"

#: src/screenshot.c:304
#, c-format
msgid "Allow %s to Take a Screenshot?"
msgstr "Разрешить приложению \"%s\" сделать снимок экрана?"

#: src/screenshot.c:305
#, c-format
msgid "%s wants to take a screenshot"
msgstr "Приложение \"%s\" хочет сделать снимок экрана"

#. Note: this will set the screenshot permission for all unsandboxed
#. * apps for which an app ID can't be determined.
#.
#: src/screenshot.c:316
msgid "Allow Apps to Take Screenshots?"
msgstr "Разрешить приложениям делать снимки экрана?"

#: src/screenshot.c:317
msgid "An app wants to take screenshots at any time"
msgstr "Приложение хочет делать снимки экрана в любое время"

#: src/screenshot.c:321
msgid "Allow to Take a Screenshot?"
msgstr "Разрешить сделать снимок экрана?"

#: src/screenshot.c:322
msgid "An app wants to take a screenshot"
msgstr "Приложение хочет сделать снимок экрана"

#: src/settings.c:196 src/settings.c:235
msgid "Requested setting not found"
msgstr "Запрашиваемая настройка не найдена"

#: src/usb.c:1333
msgid "Device not available"
msgstr "Устройство недоступно"

#: src/usb.c:1347
msgid "Not allowed"
msgstr "Запрещено"

#: src/wallpaper.c:198
#, c-format
msgid "Allow %s to Set Backgrounds?"
msgstr "Разрешить приложению \"%s\" устанавливать фоновые изображения?"

#: src/wallpaper.c:199
#, c-format
